{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lingjingwanxiang.cn/schemas/router-decision.schema.json",
  "title": "RouterDecision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "trace_id",
    "route_id",
    "selected_provider",
    "selected_model",
    "fallback_reason",
    "tool_plan",
    "decision_basis"
  ],
  "properties": {
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "route_id": {
      "type": "string",
      "minLength": 1
    },
    "entrypoint": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "selected_provider": {
      "type": "string",
      "minLength": 1
    },
    "selected_model": {
      "type": "string",
      "minLength": 1
    },
    "tool_plan": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dataset_scopes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "fallback_reason": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "fallback": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["provider", "model", "condition"],
      "properties": {
        "provider": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "condition": {
          "type": "string"
        }
      }
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "document_id"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["document", "chunk"]
          },
          "document_id": {
            "type": "string",
            "minLength": 1
          },
          "chunk_id": {
            "type": ["string", "null"],
            "minLength": 1
          },
          "uri": {
            "type": ["string", "null"],
            "minLength": 1
          }
        }
      }
    },
    "decision_basis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["matched_rules", "reasons"],
      "properties": {
        "matched_rules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "skipped_tools": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
