{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lingjingwanxiang.cn/schemas/tool-result.schema.json",
  "title": "ToolResult",
  "type": "object",
  "additionalProperties": false,
  "required": ["tool_name", "success"],
  "properties": {
    "tool_name": {
      "type": "string",
      "minLength": 1
    },
    "success": {
      "type": "boolean"
    },
    "data": {
      "type": ["object", "array", "string", "number", "boolean", "null"]
    },
    "error": {
      "type": ["string", "null"]
    },
    "meta": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "mock": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        },
        "audit_event_id": {
          "type": "string"
        }
      }
    }
  }
}
