{
  "title": "LJWX Platform Observability",
  "uid": "ljwx-platform-obsv",
  "tags": ["ljwx", "platform", "k3s", "observability"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "LJWX Platform Running Pods",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "datasource": "Prometheus",
      "targets": [
        {"refId": "A", "expr": "sum(kube_pod_status_phase{namespace=\"ljwx-platform\",phase=\"Running\"})"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Request Rate (RPS)",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "datasource": "Prometheus",
      "targets": [
        {"refId": "A", "expr": "sum(rate(http_server_requests_seconds_count{namespace=\"ljwx-platform\"}[5m]))"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "5xx Error Ratio",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_count{namespace=\"ljwx-platform\",status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_server_requests_seconds_count{namespace=\"ljwx-platform\"}[5m])), 0.001)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.01},
              {"color": "red", "value": 0.05}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Latency p95 (s)",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{namespace=\"ljwx-platform\"}[5m])))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP Throughput by Status",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate(http_server_requests_seconds_count{namespace=\"ljwx-platform\"}[5m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Latency p95 by URI",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (uri, le) (rate(http_server_requests_seconds_bucket{namespace=\"ljwx-platform\"}[5m])))",
          "legendFormat": "{{uri}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 7,
      "type": "logs",
      "title": "LJWX Error Logs (Loki)",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 12},
      "datasource": "Loki",
      "targets": [
        {"refId": "A", "expr": "{namespace=\"ljwx-platform\"} |= \"ERROR\""}
      ]
    },
    {
      "id": 8,
      "type": "logs",
      "title": "LJWX Warn Logs (Loki)",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 12},
      "datasource": "Loki",
      "targets": [
        {"refId": "A", "expr": "{namespace=\"ljwx-platform\"} |= \"WARN\""}
      ]
    }
  ]
}
